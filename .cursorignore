# =============================================================================
# .cursorignore — Cursor IDE / VS Code
# Reduz indexacao e file watchers do Cursor.
# internal_template_version: 1.0.0
#
# Sintaxe: gitignore-style. Cursor respeita .gitignore por padrao; este
# ficheiro complementa com pastas que nao devem ser indexadas pelo IDE.
# =============================================================================

# --- Pastas especificas do projecto (ajustar conforme necessario) ---
# MySQL/
# SQLite/
# MSSqlcmd/
# Exemplos/
backup/
Backup/

# --- Build outputs (Delphi + FPC) ---
Compiled/
lib/
__history/
__recovery/

# --- Binarios Delphi/FPC ---
*.exe
*.bpl
*.bpi
*.dcp
*.dcu
*.drc
*.map
*.dres
*.rsm
*.tds
*.lib
*.a
*.o
*.ocx
*.ppu
*.compiled
*.identcache
*.local
*.dsk
*.dsv
*.~*

# --- Resources LSP/IDE (binarios grandes) ---
ZipFileORM.delphilsp.json
ZipFileORM.identcache
ZipFileORM*.res
ZipFileORM*.ico

# --- Ferramentas de IA (mirrors — nao indexar contexto duplicado) ---
.claude/
.continue/
.opencode/

# --- Backups e arquivos temporarios ---
*.bak
*.bak2
*.claude.bak
*.tmp
*.log
*.swp
*.swo
*~

# --- Documentacao extensa (consulta sob demanda, nao auto-index) ---
Documentation/
CHANGELOG.md

# --- Plans gerados (consultar sob demanda) ---
.claude/plans/
.cursor/plans/
