## Modo Slim â€” Connection + Tables (quick start)

```pascal
uses
  Providers.Connection.Interfaces, Providers.Connection,
  Providers.Database.Tables.Interfaces, Providers.Database.Tables;

var
  LConn  : IConnection;
  LTables: ITables;
begin
  // 1) ConexĂŁo fluente
  LConn := TConnection.New
    .DatabaseType(dtPostgreSQL)
    .Host('localhost').Port(5432)
    .Database('mydb').Username('user').Password('pass')
    .Connect;
  try
    // 2) Metadados
    LTables := TTables.New;
    LTables.Connection(LConn).LoadFromConnection;

    // 3) DML via QueryBuilder
    LDS := TQueryBuilder.New.Connection(LConn)
      .Select('*').From('tabela').Where('id', '=', 1)
      .Execute; // retorna TDataSet â€” fazer Free apĂłs uso

    // 4) TransaĂ§ĂŁo
    LConn.BeginTransaction;
    try
      LConn.ExecuteCommand('UPDATE tabela SET nome = :nome WHERE id = :id', [...]);
      LConn.Commit;
    except
      LConn.Rollback;
      raise;
    end;
  finally
    LConn.Disconnect;
  end;
end;
```

