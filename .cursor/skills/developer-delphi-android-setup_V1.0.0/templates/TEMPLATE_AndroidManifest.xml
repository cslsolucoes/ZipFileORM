<?xml version="1.0" encoding="utf-8"?>
<!--
  TEMPLATE: AndroidManifest.template.xml para projetos Delphi FMX

  INSTRUCOES:
  1. Copiar este arquivo para a pasta do projeto com o nome: AndroidManifest.template.xml
  2. Configurar em: Project > Options > Building > Android > Manifest file
  3. Descomentar/adicionar as permissoes necessarias para o seu app
  4. NAO remover os placeholders entre % — sao substituidos automaticamente no build
  5. Substituir comentarios [DESCREVER] pelo conteudo real

  PLACEHOLDERS (substituidos automaticamente pelo RAD Studio):
    %package%          → Application ID do .dproj
    %versionCode%      → Android_VersionCode do .dproj
    %versionName%      → Android_VersionName do .dproj
    %minSdkVersion%    → Android_MinSdkVersion do .dproj
    %targetSdkVersion% → Android_TargetSdkVersion do .dproj
    %label%            → Nome do app
    %libNameValue%     → Nome da .so gerada
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
  package="%package%"
  android:versionCode="%versionCode%"
  android:versionName="%versionName%">

  <uses-sdk
    android:minSdkVersion="%minSdkVersion%"
    android:targetSdkVersion="%targetSdkVersion%"/>

