{
  "_template_info": "Template base para .vscode/tasks.json — tasks bootstrap/sync; cwd e paths relativos sempre ${workspaceFolder}. Fonte: .cursor/Templates/mirror-config/",
  "_template_version": "1.1.1",
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Mirror Bootstrap: Auto Start",
      "type": "shell",
      "windows": {
        "command": "python",
        "args": [".cursor/scripts/bootstrap_autostart_mirrors.py"]
      },
      "linux": {
        "command": "python3",
        "args": [".cursor/scripts/bootstrap_autostart_mirrors.py"]
      },
      "osx": {
        "command": "python3",
        "args": [".cursor/scripts/bootstrap_autostart_mirrors.py"]
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
