# ==============================================================================
# fpc64.opts - {PROJECT_NAME} (x86_64-win64)
# Uso: fpc @fpc64.opts {PROJECT_DPR}  (ou .lpi na IDE)
# Executar a partir da raiz do projeto: {REPO_ROOT}
# ==============================================================================
# BASE FPC: {FPC_ROOT}
# Com USE_SQLDB: units SQLdb em {FPC_ROOT}\units\x86_64-win64\fcl-db
# Com USE_ZEOS: units Zeos em {FPC_OPM_ROOT}\zeosdbo\...
# Placeholders: substituir todos os {PLACEHOLDER} antes de usar.
# ==============================================================================

-Mdelphi
-Twin64
-Px86_64

# Include (ORM.Defines.inc, etc.)
-Fi.
-Fisrc

