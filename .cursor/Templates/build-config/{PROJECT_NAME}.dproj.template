<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{PROJECT_GUID}</ProjectGuid>
        <ProjectVersion>{PROJECT_VERSION}</ProjectVersion>
        <FrameworkType>VCL</FrameworkType>
        <Base>True</Base>
        <Config Condition="'$(Config)'==''">Debug</Config>
        <Platform Condition="'$(Platform)'==''">Win32</Platform>
        <ProjectName Condition="'$(ProjectName)'==''">{PROJECT_NAME}</ProjectName>
        <!-- Win32 (bit 0 = 1) + Win64 (bit 1 = 2) = 3 -->
        <TargetedPlatforms>3</TargetedPlatforms>
        <AppType>Application</AppType>
        <MainSource>{PROJECT_NAME}.dpr</MainSource>
    </PropertyGroup>

    <!-- =====================================================================
         HERANCA DE CONFIGURACOES (Config/Platform inheritance chain)
         Cfg_1 = Debug | Cfg_2 = Release
         Ordem de avaliacao: Base -> Cfg_N -> Cfg_N_PlatformX
         ===================================================================== -->

    <PropertyGroup Condition="'$(Config)'=='Base' or '$(Base)'!=''">
        <Base>true</Base>
    </PropertyGroup>

    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Base)'=='true') or '$(Base_Win32)'!=''">
        <Base_Win32>true</Base_Win32>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>

    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Base)'=='true') or '$(Base_Win64)'!=''">
        <Base_Win64>true</Base_Win64>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Config)'=='Debug' or '$(Cfg_1)'!=''">
        <Cfg_1>true</Cfg_1>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>

    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Cfg_1)'=='true') or '$(Cfg_1_Win32)'!=''">
        <Cfg_1_Win32>true</Cfg_1_Win32>
        <CfgParent>Cfg_1</CfgParent>
        <Cfg_1>true</Cfg_1>
        <Base>true</Base>
    </PropertyGroup>

    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Cfg_1)'=='true') or '$(Cfg_1_Win64)'!=''">
        <Cfg_1_Win64>true</Cfg_1_Win64>
        <CfgParent>Cfg_1</CfgParent>
        <Cfg_1>true</Cfg_1>
        <Base>true</Base>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Config)'=='Release' or '$(Cfg_2)'!=''">
        <Cfg_2>true</Cfg_2>
        <CfgParent>Base</CfgParent>
        <Base>true</Base>
    </PropertyGroup>

    <PropertyGroup Condition="('$(Platform)'=='Win32' and '$(Cfg_2)'=='true') or '$(Cfg_2_Win32)'!=''">
        <Cfg_2_Win32>true</Cfg_2_Win32>
        <CfgParent>Cfg_2</CfgParent>
        <Cfg_2>true</Cfg_2>
        <Base>true</Base>
    </PropertyGroup>

    <PropertyGroup Condition="('$(Platform)'=='Win64' and '$(Cfg_2)'=='true') or '$(Cfg_2_Win64)'!=''">
        <Cfg_2_Win64>true</Cfg_2_Win64>
        <CfgParent>Cfg_2</CfgParent>
        <Cfg_2>true</Cfg_2>
        <Base>true</Base>
    </PropertyGroup>

    <!-- =====================================================================
         CONFIGURACOES BASE (comuns a todas plataformas/configuracoes)
         ===================================================================== -->

    <PropertyGroup Condition="'$(Base)'!=''">
        <!-- Caminhos de saida: $(Platform)\$(Config) e.g. Win32\Debug -->
        <DCC_DcuOutput>.\$(Platform)\$(Config)</DCC_DcuOutput>
        <DCC_ExeOutput>.\$(Platform)\$(Config)</DCC_ExeOutput>
        <DCC_E>false</DCC_E>
        <DCC_N>false</DCC_N>
        <DCC_S>false</DCC_S>
        <DCC_F>false</DCC_F>
        <DCC_K>false</DCC_K>
        <!-- Namespaces VCL -->
        <DCC_Namespace>Winapi;System.Win;Data.Win;Datasnap.Win;Web.Win;Soap.Win;Xml.Win;System;Xml;Data;Datasnap;Web;Soap;Vcl;Vcl.Imaging;Vcl.Touch;Vcl.Samples;Vcl.Shell;$(DCC_Namespace)</DCC_Namespace>
        <Icon_MainIcon>$(BDS)\bin\delphi_PROJECTICON.ico</Icon_MainIcon>
        <SanitizedProjectName>{PROJECT_NAME}</SanitizedProjectName>
    </PropertyGroup>

    <!-- =====================================================================
         WIN32 — Base
         ===================================================================== -->

    <PropertyGroup Condition="'$(Base_Win32)'!=''">
        <DCC_UsePackage>rtl;vcl;vclimg;vclwinx;vclactnband;vcldb;vcljpg;vclx;dbrtl;xmlrtl;inet;IndyCore;IndyProtocols;IndySystem;FireDAC;FireDACCommon;FireDACCommonDriver;$(DCC_UsePackage)</DCC_UsePackage>
        <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
        <VerInfo_Keys>CompanyName=;FileDescription={PROJECT_NAME};FileVersion=1.0.0.0;InternalName=;LegalCopyright=;LegalTrademarks=;OriginalFilename={PROJECT_NAME}.exe;ProductName={PROJECT_NAME};ProductVersion=1.0.0.0;Comments=</VerInfo_Keys>
    </PropertyGroup>

    <!-- =====================================================================
         WIN64 — Base
         ===================================================================== -->

    <PropertyGroup Condition="'$(Base_Win64)'!=''">
        <DCC_UsePackage>rtl;vcl;vclimg;vclwinx;vclactnband;vcldb;vcljpg;vclx;dbrtl;xmlrtl;inet;IndyCore;IndyProtocols;IndySystem;FireDAC;FireDACCommon;FireDACCommonDriver;$(DCC_UsePackage)</DCC_UsePackage>
        <VerInfo_IncludeVerInfo>true</VerInfo_IncludeVerInfo>
        <VerInfo_Keys>CompanyName=;FileDescription={PROJECT_NAME};FileVersion=1.0.0.0;InternalName=;LegalCopyright=;LegalTrademarks=;OriginalFilename={PROJECT_NAME}.exe;ProductName={PROJECT_NAME};ProductVersion=1.0.0.0;Comments=</VerInfo_Keys>
    </PropertyGroup>

    <!-- =====================================================================
         DEBUG — configuracoes comuns
         ===================================================================== -->

    <PropertyGroup Condition="'$(Cfg_1)'!=''">
        <DCC_Define>DEBUG;{CONDITIONAL_DEFINES};$(DCC_Define)</DCC_Define>
        <DCC_Optimize>false</DCC_Optimize>
        <DCC_GenerateStackFrames>true</DCC_GenerateStackFrames>
        <DCC_DebugInformation>2</DCC_DebugInformation>
        <DCC_LocalSymbols>true</DCC_LocalSymbols>
        <DCC_SymbolReferenceInfo>1</DCC_SymbolReferenceInfo>
        <BT_BuildType>Debug</BT_BuildType>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Cfg_1_Win32)'!=''">
        <DCC_ExeOutput>Compiled\EXE\Debug\Win32</DCC_ExeOutput>
        <DCC_DcuOutput>Compiled\DCU\Debug\Win32</DCC_DcuOutput>
        <DCC_BplOutput>Compiled\DCP\Debug\Win32</DCC_BplOutput>
        <DCC_DcpOutput>Compiled\DCP\Debug\Win32</DCC_DcpOutput>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Cfg_1_Win64)'!=''">
        <DCC_ExeOutput>Compiled\EXE\Debug\Win64</DCC_ExeOutput>
        <DCC_DcuOutput>Compiled\DCU\Debug\Win64</DCC_DcuOutput>
        <DCC_BplOutput>Compiled\DCP\Debug\Win64</DCC_BplOutput>
        <DCC_DcpOutput>Compiled\DCP\Debug\Win64</DCC_DcpOutput>
    </PropertyGroup>

    <!-- =====================================================================
         RELEASE — configuracoes comuns
         ===================================================================== -->

    <PropertyGroup Condition="'$(Cfg_2)'!=''">
        <DCC_Define>RELEASE;{CONDITIONAL_DEFINES};$(DCC_Define)</DCC_Define>
        <DCC_Optimize>true</DCC_Optimize>
        <DCC_GenerateStackFrames>false</DCC_GenerateStackFrames>
        <DCC_DebugInformation>0</DCC_DebugInformation>
        <DCC_LocalSymbols>false</DCC_LocalSymbols>
        <BT_BuildType>Release</BT_BuildType>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Cfg_2_Win32)'!=''">
        <DCC_ExeOutput>Compiled\EXE\Release\Win32</DCC_ExeOutput>
        <DCC_DcuOutput>Compiled\DCU\Release\Win32</DCC_DcuOutput>
        <DCC_BplOutput>Compiled\DCP\Release\Win32</DCC_BplOutput>
        <DCC_DcpOutput>Compiled\DCP\Release\Win32</DCC_DcpOutput>
    </PropertyGroup>

    <PropertyGroup Condition="'$(Cfg_2_Win64)'!=''">
        <DCC_ExeOutput>Compiled\EXE\Release\Win64</DCC_ExeOutput>
        <DCC_DcuOutput>Compiled\DCU\Release\Win64</DCC_DcuOutput>
        <DCC_BplOutput>Compiled\DCP\Release\Win64</DCC_BplOutput>
        <DCC_DcpOutput>Compiled\DCP\Release\Win64</DCC_DcpOutput>
    </PropertyGroup>

    <!-- =====================================================================
         ITENS DO PROJETO
         ===================================================================== -->

    <ItemGroup>
        <DelphiCompile Include="$(MainSource)">
            <MainSource>MainSource</MainSource>
        </DelphiCompile>
        <BuildConfiguration Include="Base">
            <Key>Base</Key>
        </BuildConfiguration>
        <BuildConfiguration Include="Debug">
            <Key>Cfg_1</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
        <BuildConfiguration Include="Release">
            <Key>Cfg_2</Key>
            <CfgParent>Base</CfgParent>
        </BuildConfiguration>
    </ItemGroup>

    <!-- =====================================================================
         EXTENSOES DO PROJETO
         ===================================================================== -->

    <ProjectExtensions>
        <Borland.Personality>Delphi.Personality.12</Borland.Personality>
        <Borland.ProjectType>Application</Borland.ProjectType>
        <BorlandProject>
            <Delphi.Personality>
                <Source>
                    <Source Name="MainSource">{PROJECT_NAME}.dpr</Source>
                </Source>
            </Delphi.Personality>
            <Deployment Version="5">
                <DeployFile LocalName="Win32\Debug\{PROJECT_NAME}.exe" Configuration="Debug" Class="ProjectOutput">
                    <Platform Name="Win32">
                        <RemoteName>{PROJECT_NAME}.exe</RemoteName>
                        <Overwrite>true</Overwrite>
                    </Platform>
                </DeployFile>
                <DeployFile LocalName="Win64\Debug\{PROJECT_NAME}.exe" Configuration="Debug" Class="ProjectOutput">
                    <Platform Name="Win64">
                        <RemoteName>{PROJECT_NAME}.exe</RemoteName>
                        <Overwrite>true</Overwrite>
                    </Platform>
                </DeployFile>
            </Deployment>
            <Platforms>
                <Platform value="Win32">True</Platform>
                <Platform value="Win64">True</Platform>
            </Platforms>
        </BorlandProject>
        <ProjectFileVersion>12</ProjectFileVersion>
    </ProjectExtensions>

    <!-- =====================================================================
         IMPORTS MSBuild — obrigatorios
         ===================================================================== -->

    <Import Project="$(BDS)\Bin\CodeGear.Delphi.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Delphi.Targets')"/>
    <Import Project="$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj" Condition="Exists('$(APPDATA)\Embarcadero\$(BDSAPPDATABASEDIR)\$(PRODUCTVERSION)\UserTools.proj')"/>
    <Import Project="$(MSBuildProjectName).deployproj" Condition="Exists('$(MSBuildProjectName).deployproj')"/>
</Project>
