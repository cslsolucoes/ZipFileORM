{ =============================================================================
  {PROJECT_NAME} - Programa principal FPC/Lazarus (LCL)

  Descrição:
  Ponto de entrada do projeto {PROJECT_NAME} em Free Pascal + Lazarus (LCL).
  Inicializa a aplicação e cria o formulário principal.

  Características:
  - Framework: LCL (Lazarus Component Library)
  - Formulário principal: T{MAIN_FORM_CLASS} ({MAIN_FORM_UNIT})
  - Cross-platform: Windows, Linux, macOS

  Project:        {PROJECT_NAME}
  ProjectVersion: {PROJECT_VERSION}
  FileVersion:    1.0.0
  Author:         Claiton de Souza Linhares
  Date:           {DATE}

  Changelog (file):
  - 1.0.0 ({DATE}): criação via bootstrap-build-config.ps1.
  ============================================================================= }
program {PROJECT_NAME};

{$mode objfpc}{$H+}

uses
  {$IFDEF UNIX}
  cthreads,
  {$ENDIF}
  {$IFDEF HASAMIGA}
  athreads,
  {$ENDIF}
  Interfaces, // LCL widgetset
  Forms,
  {MAIN_FORM_UNIT} in 'src\Views\{MAIN_FORM_UNIT}.pas' {{MAIN_FORM_CLASS}}
  { adicionar units aqui };

{$R *.res}

begin
  RequireDerivedFormResource := True;
  Application.Scaled := True;
  {$PUSH}{$WARN 5044 OFF}
  Application.MainFormOnTaskbar := True;
  {$POP}
  Application.Initialize;
  Application.CreateForm(T{MAIN_FORM_CLASS}, {MAIN_FORM_INSTANCE});
  Application.Run;
end.
